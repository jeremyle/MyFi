<?xml version="1.0" encoding="utf-8"?>
<!--
    Constellation icon — 108×108dp viewport
    Safe zone: 72dp circle centred at (54,54) — all nodes are within 35dp of centre.

    Constellation nodes (centre x, centre y, radius):
      A  (26, 74, 3.5) — bottom-left anchor, white
      B  (40, 60, 2.5) — white
      C  (50, 66, 2.0) — white  ← slight dip adds realism
      D  (56, 46, 3.0) — gold   ← first peak
      E  (68, 52, 2.5) — white
      F  (78, 34, 3.5) — gold   ← highest point, top-right

    Circle path formula: M (cx-r),cy  a r,r,0,1,0,(2r),0  a r,r,0,1,0,-(2r),0  z
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Ambient background sparkles (tiny, low opacity) ─────────────── -->
    <path android:pathData="M33,37 a1,1,0,1,0,2,0 a1,1,0,1,0,-2,0 z"   android:fillColor="#44FFFFFF" />
    <path android:pathData="M61,76 a1,1,0,1,0,2,0 a1,1,0,1,0,-2,0 z"   android:fillColor="#33FFFFFF" />
    <path android:pathData="M81,56 a1,1,0,1,0,2,0 a1,1,0,1,0,-2,0 z"   android:fillColor="#44FFFFFF" />
    <path android:pathData="M23.2,46 a0.8,0.8,0,1,0,1.6,0 a0.8,0.8,0,1,0,-1.6,0 z" android:fillColor="#33FFFFFF" />
    <path android:pathData="M71,22 a1.2,1.2,0,1,0,2.4,0 a1.2,1.2,0,1,0,-2.4,0 z" android:fillColor="#22FFFFFF" />

    <!-- ── Glow halos (drawn behind nodes) ─────────────────────────────── -->
    <!-- Halo: A (white, subtle) -->
    <path android:pathData="M20,74 a6,6,0,1,0,12,0 a6,6,0,1,0,-12,0 z"       android:fillColor="#22FFFFFF" />
    <!-- Halo: D (gold peak) -->
    <path android:pathData="M50.5,46 a5.5,5.5,0,1,0,11,0 a5.5,5.5,0,1,0,-11,0 z" android:fillColor="#33FFD700" />
    <!-- Halo: F (gold top — brightest) -->
    <path android:pathData="M72,34 a6,6,0,1,0,12,0 a6,6,0,1,0,-12,0 z"       android:fillColor="#44FFD700" />

    <!-- ── Connecting lines ─────────────────────────────────────────────── -->
    <path
        android:pathData="M26,74 L40,60 L50,66 L56,46 L68,52 L78,34"
        android:fillColor="#00000000"
        android:strokeColor="#BAFFD700"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- ── Star nodes ───────────────────────────────────────────────────── -->
    <!-- A: bottom-left anchor (white) -->
    <path android:pathData="M22.5,74 a3.5,3.5,0,1,0,7,0 a3.5,3.5,0,1,0,-7,0 z" android:fillColor="#FFFFFF" />
    <!-- B (white) -->
    <path android:pathData="M37.5,60 a2.5,2.5,0,1,0,5,0 a2.5,2.5,0,1,0,-5,0 z" android:fillColor="#FFFFFF" />
    <!-- C: dip (white, smallest) -->
    <path android:pathData="M48,66 a2,2,0,1,0,4,0 a2,2,0,1,0,-4,0 z"           android:fillColor="#FFFFFF" />
    <!-- D: first peak (gold) -->
    <path android:pathData="M53,46 a3,3,0,1,0,6,0 a3,3,0,1,0,-6,0 z"           android:fillColor="#FFD700" />
    <!-- E (white) -->
    <path android:pathData="M65.5,52 a2.5,2.5,0,1,0,5,0 a2.5,2.5,0,1,0,-5,0 z" android:fillColor="#FFFFFF" />
    <!-- F: top-right peak (gold, prominent) -->
    <path android:pathData="M74.5,34 a3.5,3.5,0,1,0,7,0 a3.5,3.5,0,1,0,-7,0 z" android:fillColor="#FFD700" />

</vector>
